<td>
  <%= svg_tag 'bars', class: 'icon is-small text-grey is-drawable' %>
  <span><%= model.name %></span>
</td>
<td>
  <p><%= model.path %></p>
  <p class="text-success"><%= model.home_path %></p>
</td>
<td>
  <%= form_with theme: 'switch', model: model, url: { action: 'update', id: model.id }, data: { controller: 'input' } do |f| %>
    <%= f.check_box :nav, data: { action: 'input#submit' }, id: nil %>
  <% end %>
</td>
<td>
  <%= form_with theme: 'switch', model: model, url: { action: 'update', id: model.id }, data: { controller: 'input' } do |f| %>
    <%= f.check_box :published, data: { action: 'input#submit' }, id: nil %>
  <% end %>
</td>
